<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - LifeNest</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body { font-family: Arial, sans-serif; background: #f5f7fa; margin:0; }
    .dashboard-wrapper { max-width: 900px; margin: 40px auto; padding: 20px; background: #fff; border-radius: 12px; box-shadow: 0 8px 20px rgba(0,0,0,0.08); }
    h1 { color: #3674B5; }
    .welcome { font-size: 1.2rem; margin-bottom: 20px; }
    .stats { display: flex; gap: 20px; margin-bottom: 20px; }
    .stat { flex: 1; background: #eaf1fc; padding: 15px; border-radius: 10px; text-align: center; }
    .stat h3 { margin: 0 0 10px 0; color: #3674B5; }
    .stat p { margin: 0; font-weight: bold; }
    .actions a { display: inline-block; margin-right: 15px; padding: 10px 15px; background: #3674B5; color: #fff; border-radius: 8px; text-decoration: none; }
    .actions a:hover { background: #285a9c; }
  </style>
</head>
<body>
  <div class="dashboard-wrapper">
    <h1>Dashboard</h1>
    <p class="welcome">Welcome, <%= userName %>!</p>

    <div class="stats">
      <div class="stat">
        <h3>Messages</h3>
        <p>5</p>
      </div>
      <div class="stat">
        <h3>Tasks</h3>
        <p>12</p>
      </div>
      <div class="stat">
        <h3>Notifications</h3>
        <p>3</p>
      </div>
    </div>

    <div class="actions">
      <a href="/profile">Profile</a>
      <a href="/settings">Settings</a>
      <a href="/logout">Logout</a>
    </div>
  </div>
</body>
</html>