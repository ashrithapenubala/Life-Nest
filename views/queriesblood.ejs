<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your Queries | LifeNest</title>

<!-- Bootstrap & Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
/* ====== Base ====== */
body {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  margin: 0;
  background: linear-gradient(to right, #f8fbff, #eef3fb);
  font-family: 'Segoe UI', sans-serif;
}

/* ====== Form Container ====== */
.query-container {
  background: white;
  width: 95%;
  max-width: 520px;
  padding: 40px;
  border-radius: 15px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  text-align: center;
  animation: fadeIn 1s ease;
}

/* ====== Heading ====== */
.query-container h2 {
  color: #2f58cd;
  font-weight: 700;
  font-size: 1.9rem;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.query-container p {
  color: #555;
  margin-bottom: 25px;
  font-size: 1rem;
}

/* ====== Input Fields ====== */
.form-control {
  border: 2px solid #cfd9f3;
  border-radius: 10px;
  padding: 10px 15px;
  transition: all 0.3s;
  font-size: 1rem;
}
.form-control:focus {
  border-color: #4A8BEA;
  box-shadow: 0 0 8px rgba(74,139,234,0.3);
}

/* ====== Submit Button ====== */
.btn-primary {
  background: linear-gradient(90deg, #357ae8, #4A8BEA);
  border: none;
  border-radius: 10px;
  padding: 10px 0;
  font-weight: 600;
  font-size: 1.1rem;
  transition: 0.3s;
}
.btn-primary:hover {
  background: linear-gradient(90deg, #2f58cd, #3b6ad6);
  transform: scale(1.03);
}

/* ====== Icons ====== */
.icon {
  color: #4A8BEA;
  font-size: 2rem;
  margin-bottom: 8px;
}

/* ====== Animation ====== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
</head>

<body>

<div class="query-container">
  <i class="bi bi-question-circle-fill icon"></i>
  <h2>Your Queries, Our Help</h2>
  <p>We’re here to guide and assist you. Please share your concern below.</p>

<form action="/queriesblood" method="POST">

    <div class="mb-3 text-start">
      <label class="form-label"><i class="bi bi-person-fill"></i> Name</label>
      <input type="text" class="form-control" name="name" placeholder="Enter your name" required>
    </div>

    <div class="mb-3 text-start">
      <label class="form-label"><i class="bi bi-envelope-fill"></i> Email</label>
      <input type="email" class="form-control" name="email" placeholder="Enter your email" required>
    </div>

    <div class="mb-3 text-start">
      <label class="form-label"><i class="bi bi-chat-text-fill"></i> Your Query</label>
      <textarea class="form-control" name="query" rows="4" placeholder="Type your question here..." required></textarea>
    </div>

    <button type="submit" class="btn btn-primary w-100 mt-3">
      <i class="bi bi-send-fill"></i> Submit
    </button>
  </form>
</div>

</body>
</html>
