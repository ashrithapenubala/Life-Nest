<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Organ Portal | LifeNest</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
/* ===== Body & Layout ===== */
body {
  display: flex;
  margin: 0;
  min-height: 100vh;
  background: linear-gradient(to right, #f5f7fa, #c3cfe2);
  font-family: 'Segoe UI', sans-serif;
}

/* ===== Sidebar ===== */
.sidebar {
  width: 260px;
  background: linear-gradient(180deg, #4A8BEA, #356ac3);
  color: white;
  padding: 25px 20px;
  display: flex;
  flex-direction: column;
  box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
}

.sidebar h2 {
  text-align: center;
  margin-bottom: 25px;
  font-size: 1.6rem;
  font-weight: 600;
  letter-spacing: 1px;
}

.nav-link {
  color: white;
  margin: 10px 0;
  font-weight: 500;
  text-decoration: none;
  display: flex;
  align-items: center;
  cursor: pointer;
  padding: 10px 12px;
  border-radius: 8px;
  transition: all 0.2s ease;
}

.nav-link i {
  margin-right: 10px;
  font-size: 1.2rem;
}

.nav-link.active,
.nav-link:hover {
  background-color: rgba(255, 255, 255, 0.25);
  transform: translateX(5px);
}

/* ===== Main Content ===== */
.main-content {
  flex: 1;
  padding: 40px 60px;
}

.main-content h1 {
  font-weight: 700;
  color: #2b3d63;
  margin-bottom: 10px;
}

.main-content p {
  color: #4a5568;
  font-size: 1.05rem;
  margin-bottom: 30px;
}

/* ===== Organ Card ===== */
.organ-card {
  display: flex;
  align-items: center;
  background: white;
  padding: 25px;
  margin-bottom: 25px;
  border-radius: 12px;
  box-shadow: 0 3px 12px rgba(0, 0, 0, 0.1);
  transition: all 0.25s ease;
  border: 1px solid #f0f0f0;
}

.organ-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.15);
}

.organ-card img {
  width: 110px;
  height: 110px;
  object-fit: cover;
  border-radius: 10px;
  margin-right: 20px;
  border: 2px solid #e4e6eb;
}

/* ===== Organ Details ===== */
.organ-details {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 15px;
  flex-wrap: wrap;
}

.organ-details h4 {
  margin: 0 0 10px;
  flex-basis: 100%;
  color: #2b3d63;
  font-weight: 600;
}

/* ===== Buttons ===== */
.btn {
  font-weight: 500;
  border-radius: 8px;
  padding: 8px 16px;
}

.btn-primary {
  background: #4A8BEA;
  border: none;
}
.btn-primary:hover {
  background: #3b76d1;
}

.btn-success {
  background: #48bb78;
  border: none;
}
.btn-success:hover {
  background: #3da76b;
}

.btn-warning {
  background: #f6ad55;
  border: none;
}
.btn-warning:hover {
  background: #ed8936;
}

/* ===== Dropdown ===== */
.dropdown-menu {
  box-shadow: 0 3px 10px rgba(0,0,0,0.1);
  border-radius: 8px;
  overflow: hidden;
}

.dropdown-item {
  transition: background-color 0.2s ease;
}
.dropdown-item:hover {
  background-color: #f1f1f1;
}

/* ===== Responsive Design ===== */
@media (max-width: 768px) {
  body {
    flex-direction: column;
  }
  .sidebar {
    width: 100%;
    flex-direction: row;
    overflow-x: auto;
  }
  .main-content {
    padding: 20px;
  }
  .organ-card {
    flex-direction: column;
    text-align: center;
  }
  .organ-card img {
    margin: 0 0 15px 0;
  }
  .organ-details {
    justify-content: center;
  }
}
</style>
</head>

<body>
<div class="sidebar">
  <h2>LifeNest</h2>
  <ul class="nav flex-column">
    <li><a href="/" class="nav-link"><i class="bi bi-house-door"></i> Home</a></li>
    <li><a href="/organPrerequisites" class="nav-link active"><i class="bi bi-clipboard-check"></i> Pre-Requisites</a></li>
    <li><a href="/donate/organ" class="nav-link active"><i class="bi bi-heart-pulse"></i> Organ Portal</a></li>
    <li><a href="/donate/organ/form" class="nav-link"><i class="bi bi-plus-circle"></i> Donate Organ</a></li>
    <li><a href="/donate/organ/receive" class="nav-link"><i class="bi bi-droplet-half"></i> Receive Organ</a></li>
    <li><a href="#" class="nav-link"><i class="bi bi-question-circle"></i> Queries</a></li>
  </ul>
</div>

<div class="main-content">
  <h1>Organ Portal</h1>
  <p>Select an organ below to Donate, Receive, or see available Hospitals:</p>

  <% const organs = [
    { name: 'Heart', image: '/assests/heart.gif' },
    { name: 'Kidney', image: '/assests/kidney.gif' },
    { name: 'Eyes', image: '/assests/eyes.gif' },
    { name: 'Liver', image: '/assests/liver.jpg' },
    { name: 'Brain', image: '/assests/brain.gif' }
  ]; %>

  <% organs.forEach(organ => { %>
    <div class="organ-card">
      <img src="<%= organ.image %>" alt="<%= organ.name %>">
      <div class="organ-details">
        <h4><%= organ.name %></h4>
        <a href="/donate/organ/form" class="btn btn-primary">Donate</a>
        <a href="/donate/organ/receive" class="btn btn-success">Receive</a>

        <!-- Hospitals dropdown -->
        <div class="btn-group">
          <button 
            class="btn btn-warning dropdown-toggle" 
            type="button" 
            id="btn-<%= organ.name %>" 
            data-bs-toggle="dropdown" 
            aria-expanded="false">
            Available at Hospitals
          </button>
          <ul class="dropdown-menu" id="hospital-list-<%= organ.name %>">
            <li><span class="dropdown-item text-muted">Loading...</span></li>
          </ul>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // ✅ Organ names from EJS
  const organNames = JSON.parse('<%- JSON.stringify(organs.map(o => o.name)) %>');

  // ✅ Function to fetch and update hospital lists dynamically
  async function updateHospitalList(organ) {
    const ul = document.getElementById(`hospital-list-${organ}`);
    ul.innerHTML = '<li><span class="dropdown-item text-muted">Loading...</span></li>';
    try {
      const res = await fetch(`/donate/organ/hospitals?organ=${encodeURIComponent(organ)}`);
      const data = await res.json();

      ul.innerHTML = ''; // Clear previous items
      if (!data || data.length === 0) {
        ul.innerHTML = '<li><span class="dropdown-item text-muted">No hospitals available</span></li>';
      } else {
        data.forEach(item => {
          const hospitalName = item.nearbyHospital || item.hospital || item.hospital_name || "Unknown";
          const li = document.createElement("li");
          li.innerHTML = `<span class="dropdown-item">${hospitalName}</span>`;
          ul.appendChild(li);
        });
      }
    } catch (err) {
      console.error("Error fetching hospitals:", err);
      ul.innerHTML = '<li><span class="dropdown-item text-danger">Error loading hospitals</span></li>';
    }
  }

  // ✅ Load hospitals when dropdown is opened + refresh every 10s
  organNames.forEach(org => {
    const button = document.getElementById(`btn-${org}`);
    button.addEventListener("click", () => updateHospitalList(org));
    setInterval(() => updateHospitalList(org), 10000);
  });
</script>

</body>
</html>
