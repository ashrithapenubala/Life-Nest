<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Organ Receive Success - LifeNest</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(135deg, #e8f5e9, #b2dfdb);
      font-family: 'Poppins', sans-serif;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .success-card {
      background: #fff;
      padding: 40px 50px;
      border-radius: 20px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
      text-align: center;
      max-width: 500px;
      animation: fadeIn 1s ease-in-out;
    }

    .success-icon {
      font-size: 70px;
      color: #2ecc71;
      animation: pop 0.8s ease-in-out;
    }

    @keyframes pop {
      0% { transform: scale(0); }
      80% { transform: scale(1.2); }
      100% { transform: scale(1); }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    h2 {
      color: #1b5e20;
      margin-top: 15px;
      font-weight: 600;
    }

    p {
      color: #444;
      margin: 10px 0 20px;
    }

    .btn-home {
      background: #1b5e20;
      color: white;
      border-radius: 50px;
      padding: 10px 30px;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .btn-home:hover {
      background: #388e3c;
      transform: translateY(-2px);
    }

    footer {
      text-align: center;
      margin-top: 25px;
      font-size: 0.9em;
      color: #777;
    }
  </style>
</head>

<body>
  <div class="success-card">
    <i class="bi bi-check-circle-fill success-icon"></i>
    <h2>Organ Receive Request Submitted!</h2>
    <p>Thank you for registering your organ receive request with <strong>LifeNest</strong>.</p>
    <p>A confirmation email has been sent to your provided email address.</p>

    <a href="/" class="btn-home"><i class="bi bi-house-door-fill"></i> Back to Home</a>

    <footer>
      &copy; <%= new Date().getFullYear() %> LifeNest | Healing Lives Through Hope
    </footer>
  </div>
</body>
</html>
