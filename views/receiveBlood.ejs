<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body {
      display: flex;
      margin: 0;
      min-height: 100vh;
      background: #f9fafc;
      font-family: 'Segoe UI', sans-serif;
    }
    .sidebar {
      width: 280px;
      background: linear-gradient(180deg, #4A8BEA, #3578E5);
      color: white;
      padding: 25px;
      display: flex;
      flex-direction: column;
      box-shadow: 3px 0 10px rgba(0,0,0,0.1);
      border-radius: 0 15px 15px 0;
    }
    .sidebar h2 {
      text-align: center;
      margin-bottom: 25px;
      font-weight: bold;
      letter-spacing: 1px;
    }
    .nav-link {
      color: white;
      margin: 10px 0;
      font-weight: 500;
      text-decoration: none;
      display: flex;
      align-items: center;
      padding: 10px 15px;
      border-radius: 8px;
      transition: all 0.3s ease;
    }
    .nav-link i {
      margin-right: 10px;
      font-size: 1.2rem;
    }
    .nav-link:hover {
      background: rgba(255,255,255,0.15);
      transform: translateX(5px);
    }
    .nav-link.active {
      background-color: rgba(255,255,255,0.25);
      border-left: 4px solid #fff;
      font-weight: bold;
    }
    .main-content {
      flex: 1;
      padding: 40px;
      animation: fadeIn 0.6s ease-in-out;
    }
    .form-group {
      margin-bottom: 15px;
    }
    form {
      background: white;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.08);
      padding: 25px;
      transition: 0.3s ease;
    }
    form:hover {
      box-shadow: 0 0 15px rgba(0,0,0,0.15);
    }
    button {
      border-radius: 8px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }
    button:hover {
      background-color: #3578E5 !important;
      transform: scale(1.05);
      transition: 0.3s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="sidebar">
    <h2>LifeNest</h2>
    <ul class="nav flex-column">
      <li><a href="/" class="nav-link"><i class="bi bi-house-door"></i> Home</a></li>
      <li><a href="/donate" class="nav-link"><i class="bi bi-heart"></i> Blood Portal</a></li>
      <li><a href="/donate/blood/form" class="nav-link"><i class="bi bi-plus-circle"></i> Donate Blood</a></li>
      <li><a href="/donate/receive" class="nav-link active"><i class="bi bi-droplet"></i> Receive Blood</a></li>
    </ul>
  </div>

  <div class="main-content">
    <h1 class="mb-3 text-primary"><i class="bi bi-droplet-half"></i> Receive Blood Form</h1>
    <p class="text-muted">Please fill out the details below to request blood:</p>

    <form method="POST" action="/donate/receive">
      <div class="form-group">
        <label><i class="bi bi-person"></i> Patient Name:</label>
        <input type="text" name="name" class="form-control" required>
      </div>
      <div class="form-group">
        <label><i class="bi bi-calendar"></i> Patient Age:</label>
        <input type="number" name="age" class="form-control" required>
      </div>
      <div class="form-group">
        <label><i class="bi bi-bag-heart"></i> Blood Group Required:</label>
        <select name="bloodGroup" class="form-control" required>
          <option value="">Select</option>
          <option>A+</option><option>A-</option>
          <option>B+</option><option>B-</option>
          <option>O+</option><option>O-</option>
          <option>AB+</option><option>AB-</option>
        </select>
      </div>
      <div class="form-group">
        <label><i class="bi bi-telephone"></i> Phone:</label>
        <input type="tel" name="phone" class="form-control" required>
      </div>
      <div class="form-group">
        <label><i class="bi bi-envelope"></i> Email:</label>
        <input type="email" name="email" class="form-control" required>
      </div>
      <div class="form-group">
        <label><i class="bi bi-hospital"></i> Hospital Name:</label>
        <input type="text" name="hospital" class="form-control" required>
      </div>
      <div class="form-group">
        <label><i class="bi bi-geo-alt"></i> Address:</label>
        <textarea name="address" class="form-control" required></textarea>
      </div>
      <button type="submit" class="btn btn-primary mt-3"><i class="bi bi-check-circle"></i> Submit Request</button>
    </form>
  </div>
</body>
</html>
