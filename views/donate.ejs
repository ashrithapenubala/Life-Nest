<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blood Portal - LifeNest</title>

<!-- Bootstrap & Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
/* ====== Base Layout ====== */
body {
  display: flex;
  margin: 0;
  min-height: 100vh;
  background: linear-gradient(to right, #f8fbff, #eef3fb);
  font-family: 'Segoe UI', sans-serif;
}

/* ====== Sidebar ====== */
.sidebar {
  width: 270px;
  background: linear-gradient(180deg, #4A8BEA, #357AE8);
  color: white;
  padding: 25px;
  display: flex;
  flex-direction: column;
  box-shadow: 2px 0 15px rgba(0,0,0,0.1);
}
.sidebar h2 {
  text-align: center;
  margin-bottom: 25px;
  font-weight: 700;
  letter-spacing: 1px;
}
.nav-link {
  color: white;
  margin: 12px 0;
  font-weight: 500;
  text-decoration: none;
  display: flex;
  align-items: center;
  transition: 0.3s;
}
.nav-link i { margin-right: 10px; font-size: 1.2rem; }
.nav-link.active, .nav-link:hover {
  background-color: rgba(255,255,255,0.25);
  border-radius: 8px;
  padding: 8px 12px;
}

/* ====== Main Content ====== */
.main-content {
  flex: 1;
  padding: 40px 60px;
  position: relative;
  animation: fadeIn 0.8s ease;
}

/* ====== Heading ====== */
h1 {
  font-weight: 700;
  color: #2f58cd;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 2.2rem;
  margin-bottom: 15px;
}
h1 i {
  color: #e63946;
  font-size: 2rem;
}
p {
  font-size: 1.05rem;
  color: #444;
  margin-bottom: 20px;
}

/* ====== Search Bar ====== */
.search-input {
  max-width: 350px;
  margin-bottom: 25px;
  border: 2px solid #4A8BEA;
  border-radius: 8px;
  box-shadow: 0 0 10px rgba(74,139,234,0.15);
  transition: 0.3s;
}
.search-input:focus {
  border-color: #2f58cd;
  box-shadow: 0 0 15px rgba(47,88,205,0.3);
}

/* ====== Table Styling ====== */
.table-container {
  overflow-x: auto;
  margin-top: 20px;
  animation: slideUp 1s ease;
}
table {
  width: 100%;
  background: white;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  transition: 0.3s;
}
th {
  background: linear-gradient(90deg, #357ae8, #4A8BEA);
  color: white;
  padding: 15px;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  font-weight: 600;
}
td {
  vertical-align: middle;
  padding: 12px 15px;
  font-size: 1rem;
}
tr {
  transition: background 0.3s, transform 0.2s;
}
tr:hover {
  background-color: rgba(74,139,234,0.08);
  transform: scale(1.01);
}
.badge-blood {
  font-size: 0.95rem;
  font-weight: 600;
  padding: 8px 12px;
  border-radius: 8px;
  background: linear-gradient(90deg, #e63946, #f76c6c);
  box-shadow: 0 3px 10px rgba(230,57,70,0.3);
}
.text-success i {
  color: #28a745;
}

/* ====== No Results ====== */
#noResultsMsg {
  display: none;
  margin-top: 25px;
  font-weight: 600;
  font-size: 1.1rem;
  animation: fadeIn 0.5s ease;
}

/* ====== Animations ====== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(50px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
</head>
<body>

<!-- ===== Sidebar ===== -->
<div class="sidebar">
  <h2>LifeNest</h2>
  <ul class="nav flex-column">
    <li><a href="/" class="nav-link"><i class="bi bi-house-door"></i> Home</a></li>
    <li><a href="/donate" class="nav-link active"><i class="bi bi-heart-pulse"></i> Blood Portal</a></li>
    <li><a href="/prerequisites" class="nav-link"><i class="bi bi-clipboard-check"></i> Pre-Requisites</a></li>

    <li><a href="/donate/blood/form" class="nav-link"><i class="bi bi-plus-circle"></i> Donate Blood</a></li>
    <li><a href="/donate/receive" class="nav-link"><i class="bi bi-droplet"></i> Receive Blood</a></li>
    <li><a href="/queriesblood" class="nav-link"><i class="bi bi-question-circle"></i> Queries</a></li>
  </ul>
</div>

<!-- ===== Main Content ===== -->
<div class="main-content">
  <h1><i class="bi bi-heart-pulse-fill"></i> Blood Portal</h1>
  <p>Search and connect with available donors. Filter by name or blood group below:</p>
  <input type="text" id="searchInput" class="form-control search-input" placeholder="🔍 Search donors...">

  <div class="table-container">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th><i class="bi bi-person-fill"></i> Name</th>
          <th><i class="bi bi-droplet-half"></i> Blood Group</th>
          <th><i class="bi bi-check2-circle"></i> Available</th>
        </tr>
      </thead>
      <tbody id="donorTable">
        <% donors.forEach(donor => { %>
          <tr>
            <td><i class="bi bi-person-circle text-primary"></i> <%= donor.name %></td>
            <td><span class="badge badge-blood"><%= donor.blood_group %></span></td>
            <td><span class="text-success"><i class="bi bi-check-circle-fill"></i> <%= donor.available %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p id="noResultsMsg" class="text-center text-danger">
      <i class="bi bi-exclamation-triangle-fill"></i> Sorry! No matching donors found.
    </p>
  </div>
</div>

<script>
const links = document.querySelectorAll('.nav-link');
links.forEach(link => {
  link.addEventListener('click', () => {
    links.forEach(l => l.classList.remove('active'));
    link.classList.add('active');
  });
});

const searchInput = document.getElementById("searchInput");
const donorTable = document.getElementById("donorTable");
const rows = donorTable.getElementsByTagName("tr");
const noResultsMsg = document.getElementById("noResultsMsg");

searchInput.addEventListener("keyup", function() {
  const filter = this.value.toLowerCase();
  let found = false;
  Array.from(rows).forEach(row => {
    const name = row.cells[0].textContent.toLowerCase();
    const blood = row.cells[1].textContent.toLowerCase();
    if (name.includes(filter) || blood.includes(filter)) {
      row.style.display = "";
      found = true;
    } else {
      row.style.display = "none";
    }
  });
  noResultsMsg.style.display = found ? "none" : "block";
});
</script>
</body>
</html>
