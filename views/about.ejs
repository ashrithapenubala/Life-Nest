<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About LifeNest</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(to bottom right, #f3f9ff, #e8f3ff);
      margin: 0;
      padding: 0;
    }

    /* Hero Section */
    .hero {
      text-align: center;
      background: linear-gradient(to right, #007bff, #00aaff);
      color: white;
      padding: 80px 20px;
      border-radius: 0 0 50px 50px;
    }
    .hero h1 {
      font-weight: 700;
      margin-bottom: 10px;
    }
    .hero p {
      font-size: 16px;
      opacity: 0.9;
    }

    /* About Section */
    .about-section {
      text-align: center;
      padding: 60px 20px;
      max-width: 1000px;
      margin: 0 auto;
    }
    .about-section img {
      max-width: 400px;
      border-radius: 20px;
      margin-top: 20px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    /* Meet Our Creators */
    .creators-section {
      padding: 60px 20px;
      background: white;
      text-align: center;
    }
    .creators-section h2 {
      font-weight: 700;
      color: #0066ff;
      margin-bottom: 40px;
    }
    .creator-card {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 8px 20px rgba(0, 123, 255, 0.1);
      padding: 30px 20px;
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .creator-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 0 25px rgba(0, 123, 255, 0.3);
    }
    .creator-img {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      margin-bottom: 15px;
    }
    .creator-name {
      color: #007bff;
      font-weight: 600;
      font-size: 18px;
    }
    .creator-role {
      display: inline-block;
      margin-top: 10px;
      padding: 5px 15px;
      border: 1px solid #007bff;
      border-radius: 20px;
      font-size: 13px;
      color: #007bff;
      background: #f0f8ff;
    }

    /* Footer */
    footer {
      background: linear-gradient(135deg, #1c1c1c, #252525);
      color: white;
      text-align: center;
      padding: 30px 0;
      font-size: 14px;
    }
    footer a {
      color: #00aaff;
      text-decoration: none;
      margin: 0 10px;
    }
    footer a:hover {
      color: #66ccff;
    }
  </style>
</head>
<body>

  <!-- Hero Section -->
  <section class="hero">
    <h1>Empowering Life Through Generosity 💖</h1>
    <p>LifeNest connects technology and compassion to give every life a chance.</p>
  </section>

  <!-- About Section -->
  <section class="about-section">
    <h3>About LifeNest</h3>
    <p>
      LifeNest connects people in need of blood or organ donations with compassionate donors.
      Our mission is to build a bridge of hope — powered by humanity and technology.
    </p>
    <img src="/assests/about-image.jpg" alt="LifeNest Poster">
  </section>

  <!-- Meet Our Creators -->
  <section class="creators-section">
    <h2>✨ Meet Our Creators</h2>
    <div class="container">
      <div class="row justify-content-center g-4">
        <div class="col-md-4">
          <div class="creator-card">
            <img src="/assests/my-name.jpg" class="creator-img" alt="P.Ashritha">
            <div class="creator-name">P.Ashritha</div>
            <p><em>“We ought to help people through this.”</em></p>
            <div class="creator-role">💡 Founder & Visionary</div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="creator-card">
            <img src="/assests/person2.jpg" class="creator-img" alt="E.Pravallika">
            <div class="creator-name">E.Pravallika</div>
            <p><em>“Building websites that connect hearts and people.”</em></p>
            <div class="creator-role">🎨 Design & Support</div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="creator-card">
            <img src="/assests/person3.jpg" class="creator-img" alt="E.Pranathi Reddy">
            <div class="creator-name">E.Pranathi Reddy</div>
            <p><em>“Helping the community through innovative solutions.”</em></p>
            <div class="creator-role">🌍 Community Outreach</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <p>© 2025 LifeNest | Built with 💙 and purpose</p>
    <div>
      <a href="#"><i class="fab fa-facebook"></i></a>
      <a href="#"><i class="fab fa-instagram"></i></a>
      <a href="#"><i class="fab fa-x-twitter"></i></a>
    </div>
  </footer>

</body>
</html>
